#!/usr/bin/env bash
# From WSL: launch Windows Feishu/Lark with TZ via PowerShell interop.
# Prefer native windows/bin if you are already in CMD/PowerShell.
#
# Usage:
#   feishu-tz
#   LARK_TZ=America/Los_Angeles feishu-tz
#   APP_PATH='/mnt/c/Users/you/AppData/Local/Feishu/Feishu.exe' feishu-tz
#   feishu-tz --force
#   ZONELAUNCH_FORCE=1 feishu-tz
#
# Locates feishu-tz.ps1 via:
#   1) ZONELAUNCH_WINDOWS_BIN
#   2) same directory as this script (after wsl/install.sh --feishu)
#   3) repo layout: windows/wsl/bin -> windows/bin

set -euo pipefail

LARK_TZ="${LARK_TZ:-Asia/Shanghai}"
APP_PATH="${APP_PATH:-}"
PS_FORCE_ARG=""
if [[ "${1:-}" == "--force" || "${1:-}" == "-Force" || "${1:-}" == "-force" ]]; then
  PS_FORCE_ARG=" -Force"
  shift
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

resolve_ps1() {
  if [[ -n "${ZONELAUNCH_WINDOWS_BIN:-}" && -f "${ZONELAUNCH_WINDOWS_BIN}/feishu-tz.ps1" ]]; then
    echo "${ZONELAUNCH_WINDOWS_BIN}/feishu-tz.ps1"
    return 0
  fi
  if [[ -f "$SCRIPT_DIR/feishu-tz.ps1" ]]; then
    echo "$SCRIPT_DIR/feishu-tz.ps1"
    return 0
  fi
  if [[ -f "$SCRIPT_DIR/../../bin/feishu-tz.ps1" ]]; then
    echo "$SCRIPT_DIR/../../bin/feishu-tz.ps1"
    return 0
  fi
  return 1
}

if ! command -v powershell.exe >/dev/null 2>&1 && ! command -v pwsh.exe >/dev/null 2>&1; then
  echo "powershell.exe not found. Are you inside WSL on Windows?" >&2
  exit 1
fi

PS_BIN="powershell.exe"
if command -v pwsh.exe >/dev/null 2>&1; then
  PS_BIN="pwsh.exe"
fi

PS1_PATH="$(resolve_ps1)" || {
  echo "feishu-tz.ps1 not found." >&2
  echo "Run windows/wsl/install.sh --feishu from the repo, or set ZONELAUNCH_WINDOWS_BIN." >&2
  exit 1
}

if command -v wslpath >/dev/null 2>&1; then
  PS1_WIN="$(wslpath -w "$PS1_PATH")"
else
  PS1_WIN="$PS1_PATH"
fi

# Escape single quotes for PowerShell single-quoted strings.
ps_quote() {
  printf "%s" "${1//\'/\'\'}"
}

LARK_Q="$(ps_quote "$LARK_TZ")"
PS1_Q="$(ps_quote "$PS1_WIN")"
FORCE_ENV=""
if [[ -n "${ZONELAUNCH_FORCE:-}" ]]; then
  FORCE_ENV="\$env:ZONELAUNCH_FORCE='$(ps_quote "$ZONELAUNCH_FORCE")'; "
fi

if [[ -n "$APP_PATH" ]]; then
  if [[ "$APP_PATH" == /mnt/* ]] && command -v wslpath >/dev/null 2>&1; then
    APP_PATH_WIN="$(wslpath -w "$APP_PATH")"
  else
    APP_PATH_WIN="$APP_PATH"
  fi
  APP_Q="$(ps_quote "$APP_PATH_WIN")"
  exec "$PS_BIN" -NoProfile -ExecutionPolicy Bypass -Command \
    "${FORCE_ENV}\$env:LARK_TZ='$LARK_Q'; \$env:APP_PATH='$APP_Q'; & '$PS1_Q'${PS_FORCE_ARG}"
fi

exec "$PS_BIN" -NoProfile -ExecutionPolicy Bypass -Command \
  "${FORCE_ENV}\$env:LARK_TZ='$LARK_Q'; & '$PS1_Q'${PS_FORCE_ARG}"
